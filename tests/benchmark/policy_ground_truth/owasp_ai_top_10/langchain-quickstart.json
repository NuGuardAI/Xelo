        {
          "assertion_id": "models_have_provider",
          "type": "property_constraint",
          "expected_pass": true,
          "severity": "MEDIUM",
          "description": "Models should have provider information",
          "weight": 0.8,
          "expected_matches": [
            {"name": "ChatOpenAI", "provider": "openai"},
            {"name": "OpenAIEmbeddings", "provider": "openai"}
          ]
        },
        {
          "assertion_id": "no_deprecated_models",
          "type": "must_not_exist",
          "expected_pass": true,
          "severity": "HIGH",
          "description": "No deprecated models should be used",
          "weight": 1.0
        }
      ],
      "expected_gaps": [],
      "notes": "Models have provider (OpenAI) but may lack explicit version"
